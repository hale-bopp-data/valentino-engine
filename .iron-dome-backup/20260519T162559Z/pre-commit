#!/usr/bin/env bash
# ============================================================================
# EasyWay Shared Pre-Commit Hook — Iron Dome + GEDI
# ============================================================================
# Installato automaticamente da export-agent-all.sh / context-sync-local.sh
# Source: easyway-infra/scripts/git-hooks/pre-commit
#
# Checks:
#   1. Secrets scan (pattern-based)
#   2. Merge conflict markers guard (blocks <<<<<<< ======= >>>>>>>)
#   3. Docker run guard (no `docker run` in scripts)
#   4. Valentino 5th Dan governance (portal only, if frontend files staged)
#   5. GEDI trigger check (if gedi-check available)
#
# Principi: G19 (Scudo Invisibile — funziona senza eroi)
# ============================================================================

set -euo pipefail

# --- Guard Telemetry (G16, GEDI Case #103) ---
_HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
for _t in "${_HOOK_DIR}/guard-telemetry.sh" \
          "/c/EW/easyway/infra/scripts/git-hooks/guard-telemetry.sh" \
          "$HOME/easyway-infra/scripts/git-hooks/guard-telemetry.sh"; do
  if [[ -f "$_t" ]]; then source "$_t"; break; fi
done
type _guard_log &>/dev/null || _guard_log() { :; }  # no-op fallback

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

ERRORS=0

# --- 1. Iron Dome: Secrets Scan ---
echo "🛡️  Iron Dome: Pre-Commit Secrets Scan..."

SECRETS_PATTERNS=(
  'PRIVATE.KEY'
  'BEGIN RSA PRIVATE'
  'BEGIN OPENSSH PRIVATE'
  'sk-[a-zA-Z0-9]{20,}'
  'ghp_[a-zA-Z0-9]{36}'
  'AKIA[0-9A-Z]{16}'
  'password\s*[:=]\s*["\x27][^"\x27]{8,}'
  'api[_-]?key\s*[:=]\s*["\x27][^"\x27]{8,}'
  'secret\s*[:=]\s*["\x27][^"\x27]{8,}'
)

# Safe patterns — env var references, placeholders, docs (aligned with iron-dome-scan.sh)
SAFE_RE='\$\{?[A-Z_]+\}?|\$env:[A-Z_]+|process\.env\.|os\.environ|placeholder|<REDACTED>|your[_-]?api[_-]?key'

for file in $STAGED_FILES; do
  if [[ ! -f "$file" ]]; then
    continue
  fi
  # Skip binary files
  if [[ "$file" =~ \.(png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|pdf|zip|gz)$ ]]; then
    continue
  fi
  # Skip files that contain secret detection patterns as string literals
  if [[ "$file" =~ scripts/git-hooks/pre-commit$ ]]; then
    continue
  fi
  if [[ "$file" =~ iron-dome.*\.(py|sh|yml)$ ]] || [[ "$file" =~ src/ci/.*\.(py|sh)$ ]] || [[ "$file" =~ src/guards/.*\.sh$ ]]; then
    continue
  fi
  for pattern in "${SECRETS_PATTERNS[@]}"; do
    MATCHED=$(git diff --cached -- "$file" | grep -iE "$pattern" 2>/dev/null || true)
    if [[ -n "$MATCHED" ]]; then
      # Filter out safe patterns (env var refs, placeholders)
      UNSAFE=$(echo "$MATCHED" | grep -vE "$SAFE_RE" 2>/dev/null || true)
      if [[ -n "$UNSAFE" ]]; then
        echo "  🚨 POSSIBILE SECRET in $file (pattern: $pattern)"
        ERRORS=$((ERRORS + 1))
      fi
    fi
  done
done

if [[ $ERRORS -eq 0 ]]; then
  echo "✅ Secrets scan passed."
else
  echo ""
  echo "❌ Iron Dome: trovati $ERRORS possibili secrets. Commit bloccato."
  echo "   Rimuovi i secrets e riprova. Se è un falso positivo, verifica manualmente."
  _guard_log "iron-dome-secrets" "blocking" "$ERRORS secrets detected in staged files"
  exit 1
fi

# --- 2. Merge Conflict Markers Guard ---
echo "🛡️  Iron Dome: Merge Conflict Markers..."
CONFLICT_ISSUES=0

for file in $STAGED_FILES; do
  if [[ ! -f "$file" ]]; then
    continue
  fi
  if [[ "$file" =~ \.(png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|pdf|zip|gz)$ ]]; then
    continue
  fi
  if grep -qE '^(<{7}|>{7}|={7})( |$)' "$file" 2>/dev/null; then
    echo "  🚨 CONFLICT MARKERS in $file"
    CONFLICT_ISSUES=$((CONFLICT_ISSUES + 1))
  fi
done

if [[ $CONFLICT_ISSUES -eq 0 ]]; then
  echo "✅ Conflict markers check passed."
else
  echo ""
  echo "❌ Iron Dome: trovati conflict markers in $CONFLICT_ISSUES file(s). Commit bloccato."
  echo "   Risolvi i conflitti merge prima di committare."
  _guard_log "iron-dome-conflict" "blocking" "$CONFLICT_ISSUES files with conflict markers"
  exit 1
fi

# --- 3. Docker Run Guard ---
echo "🛡️  Iron Dome: Docker Run Guard..."
DOCKER_ISSUES=0

for file in $STAGED_FILES; do
  if [[ ! -f "$file" ]]; then
    continue
  fi
  if [[ "$file" =~ \.(sh|bash|ps1|yml|yaml)$ ]]; then
    if git diff --cached -- "$file" | grep -qE '^\+.*docker run ' 2>/dev/null; then
      echo "  ⚠️  'docker run' trovato in $file — usare docker compose"
      DOCKER_ISSUES=$((DOCKER_ISSUES + 1))
    fi
  fi
done

if [[ $DOCKER_ISSUES -eq 0 ]]; then
  echo "✅ Docker Run Guard passed."
else
  echo "  ⚠️  $DOCKER_ISSUES warning(s) — docker run usato. Preferire docker compose."
  _guard_log "iron-dome-docker" "advisory" "$DOCKER_ISSUES files with docker run"
  # Warning only, non blocca
fi

# --- 3.5 MCP Config Drift Guard (S245) ---
# SSoT: root .mcp.json only. Block commits of duplicate .mcp.json in subdirectories.
for file in $STAGED_FILES; do
  if [[ "$file" == ".mcp.json" ]]; then
    continue  # root .mcp.json is fine
  fi
  if [[ "$file" =~ \.mcp\.json$ ]]; then
    echo "  🚨 DUPLICATE .mcp.json: $file — SSoT is root .mcp.json only"
    echo "     Remove this file and update root .mcp.json instead."
    _guard_log "iron-dome-mcp-drift" "blocking" "duplicate .mcp.json at $file"
    exit 1
  fi
done

# --- 3.6 Git Garbage Guard + Auto-Fix (S242) ---
# Detects accidental git output (git status, git diff headers) baked into content files.
# Root cause: redirect like `git status > file.md`.
# Auto-fixes: strips garbage lines, re-stages the cleaned file.
echo "🛡️  Iron Dome: Git Garbage Guard..."
GIT_GARBAGE_FIXED=0

GIT_GARBAGE_RE='^(Your branch is up to date|Changes to be committed|Changes not staged|Untracked files:|On branch [a-z]|  \(use "git |	modified:|	new file:|	deleted:|	renamed:|Dropped refs/stash)'

for file in $STAGED_FILES; do
  if [[ ! -f "$file" ]]; then continue; fi
  if [[ "$file" =~ \.(md|txt|json|yml|yaml)$ ]]; then
    if grep -qE "$GIT_GARBAGE_RE" "$file" 2>/dev/null; then
      # Count garbage lines
      GARBAGE_COUNT=$(grep -cE "$GIT_GARBAGE_RE" "$file" 2>/dev/null || echo 0)
      # Auto-fix: remove garbage lines
      grep -vE "$GIT_GARBAGE_RE" "$file" > "${file}.clean" 2>/dev/null
      # Remove leading blank lines after cleanup
      sed -i '/./,$!d' "${file}.clean" 2>/dev/null || true
      mv "${file}.clean" "$file"
      git add "$file"
      echo "  🔧 AUTO-FIX: $file — rimosso $GARBAGE_COUNT righe di output git"
      GIT_GARBAGE_FIXED=$((GIT_GARBAGE_FIXED + 1))
    fi
  fi
done

if [[ $GIT_GARBAGE_FIXED -eq 0 ]]; then
  echo "✅ Git Garbage Guard passed."
else
  echo "  🔧 Git Garbage Guard: $GIT_GARBAGE_FIXED file(s) auto-corretti."
  _guard_log "iron-dome-git-garbage" "auto-fix" "$GIT_GARBAGE_FIXED files cleaned"
fi
# --- 4. Valentino 5th Dan: Palette + Boundary + Anti-Redundancy (portal only) ---
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
VALENTINO_SCRIPT="${REPO_ROOT}/apps/portal-frontend/scripts/validate-valentino.mjs"
FRONTEND_TOUCHED=false

for file in $STAGED_FILES; do
  if [[ "$file" =~ ^apps/portal-frontend/(public|src)/ ]] || [[ "$file" =~ ^docs/valentino/ ]]; then
    FRONTEND_TOUCHED=true
    break
  fi
done

if [[ "$FRONTEND_TOUCHED" == "true" ]] && [[ -f "$VALENTINO_SCRIPT" ]] && command -v node &>/dev/null; then
  echo "🎨 Valentino 5th Dan: Governance Check..."
  if node "$VALENTINO_SCRIPT" --enforce 2>&1; then
    echo "✅ Valentino governance passed."
  else
    echo ""
    echo "❌ Valentino: governance errors found. Commit blocked."
    echo "   Fix errors or run: node $VALENTINO_SCRIPT"
    _guard_log "valentino-5th-dan" "blocking" "governance errors in frontend files"
    exit 1
  fi
fi

# --- 5. GEDI Layer (se disponibile) ---
GEDI_CHECK=$(command -v gedi-check 2>/dev/null || echo "")
GEDI_CHECK_PY="${REPO_ROOT}/agents/scripts/gedi-check/gedi-check.py"

if [[ -n "$GEDI_CHECK" ]] || [[ -f "$GEDI_CHECK_PY" ]]; then
  RUNNER=""
  if [[ -n "$GEDI_CHECK" ]]; then
    RUNNER="$GEDI_CHECK"
  elif python3 -c "import sys; sys.exit(0)" 2>/dev/null; then
    RUNNER="python3 $GEDI_CHECK_PY"
  fi

  if [[ -n "$RUNNER" ]]; then
    COMMIT_MSG=$(cat .git/COMMIT_EDITMSG 2>/dev/null || git log -1 --format="%s" 2>/dev/null || echo "")
    DIFF_STAT=$(git diff --cached --stat 2>/dev/null | tail -1)
    $RUNNER --trigger commit --message "$COMMIT_MSG" --diff "$DIFF_STAT" 2>&1 || true
  fi
fi

exit 0
